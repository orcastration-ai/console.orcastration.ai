---
import Base from "../layouts/Base.astro";
---

<Base
  title="Orca Console — Coming Soon"
  description="Manage your agents, workflows, and deployments."
>
  <main class="coming-soon">
    <img src="/favicon.svg" alt="Orca" width="48" height="48" class="coming-soon__logo" />
    <p class="orca-section-label">Coming Soon</p>
    <h1 class="orca-section-title">
      <span class="orca-gradient-text">Console</span>
    </h1>
    <p class="orca-section-lead">Manage your agents, workflows, and deployments.</p>
    <a href="https://orcastration.ai" class="orca-link-underline">orcastration.ai</a>
  </main>
</Base>

<style>
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: var(--orca-container-gutter);
    gap: var(--orca-space-md);
  }

  .coming-soon__logo {
    margin-bottom: var(--orca-space-sm);
  }
</style>
